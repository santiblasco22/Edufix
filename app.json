{
  "expo": {
    "name": "EduFix",
    "slug": "EduFix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "edufix",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.edufix.app"
    },
    "android": {
      "package": "com.edufix.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1E3A5F"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "EduFix necesita acceso a tus fotos para adjuntar imágenes a los incidentes.",
          "cameraPermission": "EduFix necesita acceso a tu cámara para fotografiar incidentes."
        }
      ]
    ]
  }
}
